    "Quantity": 1,
    "Items": [
      {
        "Id": "S3-anchor-platform-secure",
        "DomainName": "anchor-platform-staging-1774800766.s3.us-east-1.amazonaws.com",
        "S3OriginConfig": {
          "OriginAccessIdentity": ""
        },
        "OriginAccessControlId": ""
      }
    ]
  },
  "DefaultCacheBehavior": {
